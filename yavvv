local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "YAV HUB",
   LoadingTitle = "YAV HUB | Loading...",
   LoadingSubtitle = "by fwrgotten",
   ConfigurationSaving = { Enabled = false }
})

local Main = Window:CreateTab("Main", 4483362458)

Main:CreateToggle({
   Name = "Speed Boost",
   CurrentValue = false,
   Callback = function(Value)
       _G.SpeedEnabled = Value
   end,
})

Main:CreateSlider({
   Name = "Speed Power",
   Min = 1,
   Max = 10,
   DefaultValue = 1,
   Callback = function(Value)
       _G.SpeedValue = Value
   end,
})

Main:CreateSection("TSB Exploits")

Main:CreateToggle({
   Name = "No Dash Cooldown",
   CurrentValue = false,
   Callback = function(Value)
       workspace:SetAttribute("NoDashCooldown", Value)
   end,
})

-- The Engine
game:GetService("RunService").Heartbeat:Connect(function()
    if _G.SpeedEnabled then
        local p = game.Players.LocalPlayer
        local char = p.Character
        if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
            if char.Humanoid.MoveDirection.Magnitude > 0 then
                char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame + (char.Humanoid.MoveDirection * (_G.SpeedValue or 1))
            end
        end
    end
end)

Rayfield:Notify({ Title = "Success", Content = "YAV HUB is now active!" })
